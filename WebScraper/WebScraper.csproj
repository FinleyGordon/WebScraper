<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
      <Folder Include="src\" />
    </ItemGroup>

    <!-- Install npm deps when node_modules is missing -->
    <Target Name="NpmInstall" BeforeTargets="Build"
            Condition="!Exists('$(ProjectDir)ClientApp/node_modules')">
        <Exec Command="npm install" WorkingDirectory="$(ProjectDir)ClientApp" />
    </Target>

    <!-- Build the SPA to wwwroot only for Release (dev uses `npm run dev`) -->
    <Target Name="NpmBuild" BeforeTargets="Build"
            DependsOnTargets="NpmInstall"
            Condition="'$(Configuration)' == 'Release'">
        <Exec Command="npm run build" WorkingDirectory="$(ProjectDir)ClientApp" />
    </Target>

</Project>
